  "skills": {
    "retrieval-methodology": {
      "type": "guardrail",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "检索方法论：先分类意图，再选通道，后交叉验证",
      "promptTriggers": {
        "keywords": ["搜索", "检索", "找一个", "有没有", "搜一下", "search for", "find a skill", "look for", "装上", "接入", "集成", "integrate", "对比", "compare", "选型", "选哪个", "which one", "best practice", "最佳实践"],
