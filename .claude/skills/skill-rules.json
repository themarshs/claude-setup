    "test": ["unit", "jest", "pytest", "vitest", "spec", "coverage", "tdd", "e2e"],
    "review": ["code", "pr", "pull request", "diff", "merge"],
    "build": ["npm", "yarn", "webpack", "compile", "docker"],
